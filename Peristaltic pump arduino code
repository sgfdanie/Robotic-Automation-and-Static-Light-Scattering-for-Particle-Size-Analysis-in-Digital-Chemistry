// ------------------------------------------------ Stopping a pump ------------------------------------------------------

void stopPump(char selectedPump){
  pumpStat* pump; // pointer 'pump' will store the memory address of the selected pump

  // Checking which pump has been selected
  if (selectedPump == 'A'){
    pump = &pumpA; // &pumpA = memory location of pump A
  }

  else if (selectedPump == 'B'){
    pump = &pumpB;
  }

  else if (selectedPump == 'C'){
    pump = &pumpC;
  }

  else if (selectedPump == 'D'){
    pump = &pumpD;
  }

  else{
    return;
  }

  Motor.begin(pump->driver_address); // Selects the correct motor driver based on the direction of the pointer

  Motor.speed(pump->motor_channel, 0); // Selects the correct motor channel based on the direction of the pointer with speed 0

  pump->running = false; // Updates the pump status when the motor stops running
}

// ------------------------------------ Stopping all the pumps------------------------------------------

void stopAllPumps(){
  stopPump('A');
  stopPump('B');
  stopPump('C');
  stopPump('D');
}

// -------------------------------- Verifying the runtime----------------------------------------

void updateSinglePump(pumpStat* pump){

  // If the pump is still running, check the timer
  if (pump->running == true){
    // Check if the pump time is finished
    if (millis() >= pump->stopTime){
      // Stop the motor
      Motor.begin(pump->driver_address);
      Motor.speed(pump->motor_channel, 0);

      pump->running = false; // Updates the software state when the motor stops running
    }
  }
}

// -----------------------------------Runtime update-------------------------------------
void updatePumpTimers(){
  updateSinglePump(&pumpA);
  updateSinglePump(&pumpB);
  updateSinglePump(&pumpC);
  updateSinglePump(&pumpD);
}

// ------------------------------------Operating the pumps--------------------------------------

void startPump(char selectedPump, float volume, int speed){
  float cal_factor;
  pumpStat* pump;

  if (selectedPump == 'A'){
    cal_factor = PUMP_A_CAL;
    pump = &pumpA;
  }

  else if (selectedPump == 'B'){
    cal_factor = PUMP_B_CAL;
    pump = &pumpB;
  }

  else if (selectedPump == 'C'){
    cal_factor = PUMP_C_CAL;
    pump = &pumpC;
  }

  else if (selectedPump == 'D'){
    cal_factor = PUMP_D_CAL;
    pump = &pumpD;
  }

  else{
    return;
  }
  
  // Run time calculation based on the volume and pre-established calibration factor
  float runTime_ms = volume / cal_factor;

  Motor.begin(pump->driver_address);

  Motor.speed(pump->motor_channel,speed);

  pump->running = true; // Switches the pump ON
  pump->speed = speed;
  pump->stopTime = millis() + runTime_ms; // Applies the runtime volume control
}


//--------------------------Reading Pyserial data--------------------------------
void checkSerialCommands(){
  if (Serial.available() <= 0){
    return;
  }

  String incomingData = Serial.readStringUntil('\n');
  incomingData.trim();
  incomingData.toUpperCase();

  // Stoping all pumps
  if (incomingData == "S"){
    stopAllPumps();
    return;
  }

  // Stoping selected pumps
  if (incomingData == "SA"){
    stopPump('A');
    return;
  }

  if (incomingData == "SB"){
    stopPump('B');
    return;
  }

  if (incomingData == "SC"){
    stopPump('C');
    return;
  }

  if (incomingData == "SD"){
    stopPump('D');
    return;
  }

  int commaPosition = incomingData.indexOf(',');

  if (commaPosition == -1){
    return;
  }

  String pumpText = incomingData.substring(0, commaPosition);

  String volumeText = incomingData.substring(commaPosition + 1);

  float volume = volumeText.toFloat();

  if (pumpText.startsWith("R")){
    char selectedPump =
      pumpText.charAt(1);

    startPump(selectedPump, volume, -255);
  }
  else{
    char selectedPump =
      pumpText.charAt(0);

    startPump(selectedPump, volume, 255);
  }
}

void loop(){
  checkSerialCommands();
  updatePumpTimers();
}
