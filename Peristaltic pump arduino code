/* Arduino Code for control of Grove I2C motor drivers for peristaltic pumps
with an LCD screen displaying volume of liquid dispensed */
 
#include <Wire.h>
#include <LiquidCrystal_I2C.h>
#include "Grove_I2C_Motor_Driver.h"
 
// Initialize the LCD with I2C address 0x27, 16 columns, and 2 rows
LiquidCrystal_I2C lcd(0x27, 16, 2);
 
#define DRIVER_1_ADDR 0x0f
#define DRIVER_2_ADDR 0x0a
 
#define PUMP_A MOTOR1
#define PUMP_B MOTOR2
#define PUMP_C MOTOR1
#define PUMP_D MOTOR2
 
// --- CALIBRATION FACTORS (mL per millisecond) ---
const float PUMP_A_CAL = 0.00123;
const float PUMP_B_CAL = 0.00127;
const float PUMP_C_CAL = 0.00125;
const float PUMP_D_CAL = 0.00125;

// --------------------------- Creating a struct that stores pump variables ---------------------------
struct pumpStat {
  bool running; // Checks whether the pump is running
  int speed; // Checks the speed (in this case, when the pump is running: either 255 or -255 responsible for forwards and backwards operation)
  int driver_address; // DRIVER_1/2_ADDR = either 0x0f or 0x0a as previously defined
  int motor_channel; // PUMP_X = either MOTOR 1 or MOTOR 2 as previously defined
  unsigned long stopTime; // Time at which the pump should stop
};

// Initially the pumps are switched off, hence running = false, speed = 0, stopTime = 0
pumpStat pumpA = {false, 0, DRIVER_1_ADDR, PUMP_A, 0};
pumpStat pumpB = {false, 0, DRIVER_1_ADDR, PUMP_B, 0};
pumpStat pumpC = {false, 0, DRIVER_2_ADDR, PUMP_C, 0};
pumpStat pumpD = {false, 0, DRIVER_2_ADDR, PUMP_D, 0};


